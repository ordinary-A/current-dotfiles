// =============================================
// VARIABLES
// =============================================

$bg:          #0a0e1a;
$bg-alt:      #0d1526;
$bg-module:   rgba(13, 21, 38, 0.6);
$border:      rgba(0, 212, 212, 0.12);
$accent:      #00d4d4;
$accent-dim:  #0097a7;
$text:        #cdd6f4;
$text-dim:    #4a5568;
$red:         #f38ba8;
$green:       #00d4d4;
$yellow:      #f9e2af;
$blue:        #89b4fa;
$purple:      #cba6f7;

// =============================================
// GLOBAL
// =============================================

* {
  font-family: "DepartureMono Nerd Font";
  font-size: 13px;
  border: none;
  outline: none;
  margin: 0;
  padding: 0;
  color: $text;
}

// =============================================
// BAR WINDOW
// =============================================

.bar-window {
  background-color: rgba(10, 14, 26, 0.92);
  border-bottom: 1px solid $border;
}

// =============================================
// LAUNCHER
// =============================================

.launcher {
  font-size: 16px;
  color: $accent;
  background-color: rgba(0, 212, 212, 0.08);
  border-radius: 8px;
  padding: 0 10px;
  margin: 4px 6px 4px 4px;
  transition: all 200ms ease;

  &:hover {
    background-color: rgba(0, 212, 212, 0.18);
    color: $text;
  }
}

.launcher-icon {
  font-family: "DepartureMono Nerd Font";
  font-size: 16px;
  color: $accent;
}

// =============================================
// WORKSPACES
// =============================================

.workspaces {
  margin: 0 4px;
}

.workspace-btn {
  padding: 0 10px;
  border-radius: 6px;
  color: $text-dim;
  background-color: transparent;
  margin: 4px 2px;
  transition: all 200ms ease;
  font-size: 13px;

  &:hover {
    color: $text;
    background-color: rgba(205, 214, 244, 0.08);
  }
}

.workspace-btn.active {
  color: $accent;
  background-color: rgba(0, 212, 212, 0.15);
}

.workspace-btn.occupied {
  color: $text;
}

.workspace-btn.empty {
  color: $text-dim;
}

// =============================================
// WINDOW TITLE
// =============================================

.window-title {
  color: #4a5568;
  font-size: 12px;
  padding: 0 12px;
}

// =============================================
// CLOCK
// =============================================

.clock {
  padding: 0 16px;
}

.clock-time {
  color: $text;
  font-size: 14px;
  font-weight: bold;
  letter-spacing: 1px;
}

.clock-date {
  color: $text-dim;
  font-size: 12px;
}

// =============================================
// BAR MODULES
// =============================================

.bar-module {
  padding: 0 12px;
  margin: 4px 1px;
  border-radius: 6px;
}

.volume {
  color: $accent;
}

.cpu {
  color: $blue;
}

.ram {
  color: $purple;
}

.temp {
  color: $yellow;
}

// =============================================
// PROFILE BUTTON
// =============================================

.profile-btn {
  padding: 0 10px;
  margin: 3px 8px 3px 2px;
  border-radius: 8px;
  transition: all 200ms ease;

  &:hover {
    background-color: rgba(0, 212, 212, 0.15);
  }
}

.profile-icon {
  font-family: "DepartureMono Nerd Font";
  font-size: 16px;
  color: $text;
}
